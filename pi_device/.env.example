# Pi Device Configuration
API_URL=http://localhost:8000
DEVICE_ID=PI_01
DEVICE_API_KEY=your-device-api-key-here
OFFICE_ID=1

# Hardware Configuration
RFID_PORT=/dev/ttyUSB0
RFID_BAUD=9600

FINGERPRINT_PORT=/dev/ttyUSB1
FINGERPRINT_BAUD=57600

RELAY_PIN=17
RELAY_PIN_MODE=BCM

# Sync Settings
SYNC_INTERVAL=300  # seconds
OFFLINE_MODE=True
